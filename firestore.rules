rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow write: if false;
    }

    match /entitlements/{userId} {
      allow read: if isSelf(userId);
      allow write: if false;
    }

    match /usage/{userId}/{document=**} {
      allow read: if isSelf(userId);
      allow write: if false;
    }

    match /billingEvents/{eventId} {
      allow read, write: if false;
    }

    match /storyRepos/{repoId} {
      allow read, write: if false;
    }

    match /branches/{branchId} {
      allow read, write: if false;
    }

    match /turns/{turnId} {
      allow read, write: if false;
    }

    match /branchStates/{branchId} {
      allow read, write: if false;
    }

    match /branchSnapshots/{turnId} {
      allow read, write: if false;
    }

    match /eventPatches/{patchId} {
      allow read, write: if false;
    }

    match /continuityWarnings/{warningId} {
      allow read, write: if false;
    }

    match /branchMutationLocks/{branchId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
