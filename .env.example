# Ariadne Engine API
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Frontend origin allow-list. Use a comma-separated list in production.
# Do not use * for production BYOK deployments.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage. Use memory for local demos; production NODE_ENV requires firestore unless explicitly overridden.
ARIADNE_STORAGE=memory
DATABASE_URL=postgres://ariadne:ariadne@localhost:5432/ariadne
ARIADNE_ALLOW_UNSAFE_PRODUCTION=false

# Firebase / paid usage. BYOK users can still paste a Gemini key and bypass Ariadne billing.
ARIADNE_PAID_USAGE_ENABLED=false
ARIADNE_FIREBASE_AUTH_REQUIRED=false
GEMINI_API_KEYS=
BILLING_CURRENCY=usd
APP_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ARIADNE_MIN_CHECKOUT_AMOUNT_CENTS=500
ARIADNE_DEFAULT_CHECKOUT_AMOUNT_CENTS=1000
ARIADNE_LIVE_SESSION_TTL_SECONDS=75

# Server key rotation limits, copied from the product-family Firebase pattern.
GEMINI_KEY_MAX_CONCURRENCY=1
GEMINI_KEY_REQUESTS_PER_MINUTE=12
GEMINI_KEY_REQUESTS_PER_DAY=0
GEMINI_KEY_QUOTA_COOLDOWN_SECONDS=75
GEMINI_KEY_TRANSIENT_COOLDOWN_SECONDS=12
GEMINI_KEY_AUTH_COOLDOWN_SECONDS=1800

# Model enforcement and pricing. Replace ARIADNE_MODEL_CATALOG_JSON as cheap models/prices change.
ARIADNE_DEFAULT_PROVIDER=google-ai-studio
ARIADNE_ACTOR_MODEL=gemini-flash-lite-latest
ARIADNE_CANONIZER_MODEL=gemini-flash-lite-latest
ARIADNE_LIVE_MODEL=gemini-3.1-flash-live-preview
ARIADNE_TURN_RESERVE_INPUT_TOKENS=32000
ARIADNE_TURN_RESERVE_OUTPUT_TOKENS=4000
# ARIADNE_MODEL_CATALOG_JSON={"models":{"gemini-flash-lite-latest":{"kind":"text","inputCreditMicrosPerMillionTokens":100000,"outputCreditMicrosPerMillionTokens":400000},"gemini-3.1-flash-lite":{"kind":"text","inputCreditMicrosPerMillionTokens":250000,"outputCreditMicrosPerMillionTokens":1500000},"gemini-3.1-flash-live-preview":{"kind":"live","liveBillableSeconds":30,"liveInputTokensPerSecond":25,"liveOutputTokensPerSecond":25,"liveInputCreditMicrosPerMillionTokens":250000,"liveOutputCreditMicrosPerMillionTokens":1500000}}}

# Frontend Firebase config for paid credits sign-in. Leave blank for BYOK-only local development.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_DISABLE_FIREBASE_AUTH=false
VITE_ARIADNE_API_BASE=

# Hands-free transcript-only frontend defaults.
ARIADNE_DEFAULT_STORY_TITLE=Ariadne Voice Session
ARIADNE_DEFAULT_STORY_STYLE=voice-first interactive fiction: vivid, concise, emotionally responsive, no UI instructions
# Optional BCP-47 language override for browser SpeechRecognition, e.g. en-US or fi-FI.
# ARIADNE_WEB_SPEECH_LANGUAGE=en-US

# Development-only provider. Never enable on public production deployments.
ARIADNE_ALLOW_MOCK_PROVIDER=false

# API guardrails
ARIADNE_RATE_LIMIT_MAX=120
ARIADNE_RATE_LIMIT_WINDOW=1 minute
ARIADNE_MAX_TRANSCRIPT_CHARS=12000
ARIADNE_BODY_LIMIT_BYTES=2097152
ARIADNE_CONTEXT_WINDOW_TOKENS=1048576
ARIADNE_SAFE_INPUT_BUDGET_TOKENS=900000
